#!/usr/bin/env bash
# bash-portability-linter
# Scans shell scripts for constructs that break on macOS bash 3.2 / BSD
# coreutils / Git Bash on Windows.
#
# Usage:
#   bash-portability-linter <file-or-dir> [--json]
#
# Exit codes:
#   0  clean
#   1  at least one ERROR found
#   2  only WARN found
#
# Rules are added incrementally via TDD. This is the empty scaffold.

set -u

JSON_MODE=0
TARGET=""

usage() {
  echo "Usage: bash-portability-linter <file-or-dir> [--json]" >&2
}

while [ $# -gt 0 ]; do
  case "$1" in
    --json) JSON_MODE=1; shift ;;
    -h|--help) usage; exit 0 ;;
    -*) echo "Unknown option: $1" >&2; usage; exit 64 ;;
    *)
      if [ -z "$TARGET" ]; then
        TARGET="$1"
      else
        echo "Too many arguments" >&2; usage; exit 64
      fi
      shift
      ;;
  esac
done

if [ -z "$TARGET" ]; then
  usage; exit 64
fi
if [ ! -e "$TARGET" ]; then
  echo "No such file or directory: $TARGET" >&2; exit 64
fi

ERROR_COUNT=0
WARN_COUNT=0
FILES_SCANNED=0

# Emit a violation in text mode (JSON mode added later).
# Args: file line severity rule_id rule_name suggestion
emit() {
  _file="$1"; _line="$2"; _sev="$3"; _rid="$4"; _rn="$5"; _sg="$6"
  if [ "$_sev" = "ERROR" ]; then
    ERROR_COUNT=$((ERROR_COUNT + 1))
  else
    WARN_COUNT=$((WARN_COUNT + 1))
  fi
  printf '%s:%s: [%s] %s: %s \xe2\x80\x94 %s\n' \
    "$_file" "$_line" "$_sev" "$_rid" "$_rn" "$_sg"
}

# Run a grep -nE over the file, emitting one violation per hit.
# Args: file pattern severity rule_id rule_name suggestion
grep_rule() {
  _f="$1"; _pat="$2"; _sev="$3"; _rid="$4"; _rn="$5"; _sg="$6"
  _hits=$(grep -nE "$_pat" "$_f" 2>/dev/null || true)
  [ -z "$_hits" ] && return 0
  _old_IFS="$IFS"
  IFS='
'
  for _hit in $_hits; do
    _lineno=$(printf '%s' "$_hit" | sed -E 's/^([0-9]+):.*/\1/')
    emit "$_f" "$_lineno" "$_sev" "$_rid" "$_rn" "$_sg"
  done
  IFS="$_old_IFS"
}

scan_file() {
  _f="$1"
  FILES_SCANNED=$((FILES_SCANNED + 1))

  # BP001: ${var,,} or ${var^^} bash 4+ case modification
  grep_rule "$_f" \
    '\$\{[a-zA-Z_][a-zA-Z0-9_]*(,,|\^\^)\}' \
    "ERROR" "BP001" \
    "bash 4+ case modification (\${var,,} / \${var^^})" \
    "Use tr '[:upper:]' '[:lower:]' or tr '[:lower:]' '[:upper:]'"

  # BP002: declare -A or local -A (bash 4+ associative arrays).
  # Match "declare -A" or "local -A" at word boundaries.
  grep_rule "$_f" \
    '(^|[^a-zA-Z_])(declare|local)[[:space:]]+-A([[:space:]]|$)' \
    "ERROR" "BP002" \
    "bash 4+ associative array (declare -A / local -A)" \
    "Use integer-indexed parallel key/value arrays, or a string encoding"

  # BP003: mapfile / readarray (bash 4+ builtins).
  grep_rule "$_f" \
    '(^|[^a-zA-Z_])(mapfile|readarray)([[:space:]]|$)' \
    "ERROR" "BP003" \
    "bash 4+ mapfile/readarray builtin" \
    "Use: while IFS= read -r line; do ... done < file"

  # BP004: non-portable sed -i usage.
  # Portable: sed -i.bak '...' file    (no space between -i and suffix)
  # Broken on BSD: sed -i '...' file   (BSD treats next arg as suffix)
  # Broken on GNU: sed -i '' '...' file (GNU has no empty-suffix form)
  # We flag: "sed ... -i" immediately followed by whitespace (bare -i).
  grep_rule "$_f" \
    '(^|[^a-zA-Z_])sed[[:space:]]+([^|;&]*[[:space:]])?-i[[:space:]]' \
    "ERROR" "BP004" \
    "non-portable sed -i (BSD vs GNU)" \
    "Use sed -i.bak '...' file && rm -f file.bak"

  # BP005: awk -v RS='multi-char'. BSD awk's RS is single-char only.
  # Match awk ... -v RS='XX' or "XX" where XX has 2+ chars.
  grep_rule "$_f" \
    "(^|[^a-zA-Z_])awk[^#]*-v[[:space:]]+RS=('[^']{2,}'|\"[^\"]{2,}\")" \
    "ERROR" "BP005" \
    "awk -v RS='multi-char' (BSD awk is single-char only)" \
    "Split manually in bash: while [[ \"\$s\" == *DELIM* ]]; do ...; done"

  # BP006: readlink -f is GNU-only. BSD readlink lacks -f.
  grep_rule "$_f" \
    '(^|[^a-zA-Z_])readlink[[:space:]]+-f([[:space:]]|$)' \
    "WARN" "BP006" \
    "readlink -f is GNU-only" \
    "Use: cd \"\$(dirname \"\$f\")\" && pwd"
}

if [ -f "$TARGET" ]; then
  scan_file "$TARGET"
elif [ -d "$TARGET" ]; then
  echo "Directory scanning not implemented yet" >&2
  exit 64
else
  echo "Not a file or directory: $TARGET" >&2
  exit 64
fi

if [ "$ERROR_COUNT" -gt 0 ]; then exit 1; fi
if [ "$WARN_COUNT" -gt 0 ]; then exit 2; fi
exit 0
