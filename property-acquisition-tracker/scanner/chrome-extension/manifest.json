{
  "manifest_version": 3,
  "name": "Property Scanner - Idealista",
  "version": "1.0",
  "description": "Extracts rental listings from Idealista for property investment analysis",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["*://*.idealista.it/*", "http://localhost:3456/*"],
  "content_scripts": [
    {
      "matches": ["*://*.idealista.it/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  }
}
